---
import BookingFlow from "../organisms/BookingFlow";

interface Props {
  initialServiceId?: string;
}

const { initialServiceId } = Astro.props;
---

<main class=" flex items-center justify-center">
    <div class="flex flex-col lg:flex-row gap-6 w-full max-w-6xl mx-auto items-stretch justify-center lg:p-8">
        <BookingFlow client:load initialServiceId={initialServiceId} />
    </div>
</main>
