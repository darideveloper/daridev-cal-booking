---
import Layout from '../layouts/Layout.astro';
import BookingPage from "../components/pages/index.astro";
import { fetchServices } from '../lib/api/endpoints/services';

export async function getStaticPaths() {
  const categories = await fetchServices();
  const allServices = categories.flatMap((category: any) => category.services);
  return allServices.map((service: any) => ({
    params: { id: service.id },
    props: { service },
  }));
}

const { id } = Astro.params;
---

<Layout>
    <BookingPage initialServiceId={id} />
</Layout>
